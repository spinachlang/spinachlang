{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Spinachlang",
    "scopeName": "source.spinachlang",
    "fileTypes": [
        "sph"
    ],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#all_qubit"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#gate_call"
        },
        {
            "include": "#gate_names"
        },
        {
            "include": "#storage_types"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#identifiers"
        },
        {
            "include": "#punctuation"
        }
    ],
    "repository": {
        "comments": {
            "name": "comment.line.number-sign.spinachlang",
            "match": "#.*$"
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.spinachlang",
                    "match": "\\bif\\b"
                },
                {
                    "name": "keyword.control.spinachlang",
                    "match": "\\belse\\b"
                }
            ]
        },
        "storage_types": {
            "comment": "q and b are reserved type keywords for qubit/bit declarations and qubit refs",
            "patterns": [
                {
                    "name": "storage.type.qubit.spinachlang",
                    "match": "\\bq\\b"
                },
                {
                    "name": "storage.type.bit.spinachlang",
                    "match": "\\bb\\b"
                },
                {
                    "name": "storage.type.qubit.spinachlang",
                    "match": "\\bq(?=\\s+\\d)"
                }
            ]
        },
        "all_qubit": {
            "name": "constant.language.all-qubits.spinachlang",
            "match": "\\*"
        },
        "gate_call": {
            "comment": "Gate call with arguments: GATE(args)",
            "name": "meta.function-call.spinachlang",
            "match": "\\b([A-Z][A-Z0-9]*)\\s*(\\()",
            "captures": {
                "1": {
                    "name": "entity.name.function.gate.spinachlang"
                },
                "2": {
                    "name": "punctuation.section.arguments.begin.spinachlang"
                }
            }
        },
        "gate_names": {
            "comment": "Bare gate name without arguments: UPPER_CASE identifiers",
            "name": "entity.name.function.gate.spinachlang",
            "match": "\\b[A-Z][A-Z0-9]*\\b"
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.forward.spinachlang",
                    "match": "->"
                },
                {
                    "name": "keyword.operator.arrow.reverse.spinachlang",
                    "match": "<-"
                },
                {
                    "name": "punctuation.separator.key-value.spinachlang",
                    "match": ":"
                }
            ]
        },
        "numbers": {
            "name": "constant.numeric.spinachlang",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        "identifiers": {
            "name": "variable.other.spinachlang",
            "match": "\\b[a-z][a-zA-Z0-9_]*\\b"
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.definition.list.begin.spinachlang",
                    "match": "\\["
                },
                {
                    "name": "punctuation.definition.list.end.spinachlang",
                    "match": "\\]"
                },
                {
                    "name": "punctuation.section.arguments.begin.spinachlang",
                    "match": "\\("
                },
                {
                    "name": "punctuation.section.arguments.end.spinachlang",
                    "match": "\\)"
                },
                {
                    "name": "punctuation.separator.arguments.spinachlang",
                    "match": ","
                }
            ]
        }
    }
}
